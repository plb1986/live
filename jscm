  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "type": "field",
        "domain": [
          "ott.mobaibox.com",
          "mobaibox.com"
        ],
        "outboundTag": "iptv-proxy"
      },
      {
        "type": "field",
        "port": "53",
        "outboundTag": "direct"
